# ─── Google OAuth2 ────────────────────────────────────────────────────────────
# Create at https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/oauth2callback   # local only for token generation

# Run `npm run get-token` once locally to generate this
GOOGLE_REFRESH_TOKEN=

# ─── Google Pub/Sub ───────────────────────────────────────────────────────────
# Format: projects/YOUR_GCP_PROJECT_ID/topics/YOUR_TOPIC_NAME
PUBSUB_TOPIC=projects/my-gcp-project/topics/gmail-push

# ─── Email Filter ─────────────────────────────────────────────────────────────
# Only emails from this address will be processed
ALLOWED_SENDER_EMAIL=sender@example.com

# ─── Target Webhook ───────────────────────────────────────────────────────────
TARGET_WEBHOOK_URL=https://your-server.com/webhook
TARGET_WEBHOOK_SECRET=                    # optional — sent as X-Webhook-Secret header

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=               # use service role key (server only!)

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3000
